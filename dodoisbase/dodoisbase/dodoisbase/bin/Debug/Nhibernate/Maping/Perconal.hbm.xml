<?xml version="1.0" encoding="utf-8" ?>

<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2"
                   assembly="dodoisbase"
                   namespace="dodoisbase.Nhibernate.Entites">
	<class name="Personal" table="[Сотрудники]">
		<id name="ID_Сотрудника" column="[ID_Сотрудника]">
			<generator class="native" />
		</id>
		<property name="ФИО" column="[ФИО]"/>
		<property name="Стаж" column="[Стаж]"/>
		<property name="ID_Категории" column="[ID_Категории]"/>

		<bag name="Oders" table="[Доставка]">
			<key column ="[ID_Сотрудника]"/>
			<many-to-many class ="Oder" column ="[ID_Заказа]"/>
			
		</bag>
	</class>			   
</hibernate-mapping>

