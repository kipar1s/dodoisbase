<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" 
                   assembly="dodoisbase" 
                   namespace="dodoisbase.Nhibernate.Entites">
	
	<class name="Tovar" table="[Товар]">
		<id name="ID_Товара" column="[ID_Товара]">
			<generator class="assigned" />
		</id>
		
		<many-to-one name="Ингредиенты" column="[ID_Ингредиента]" cascade="merge" />
		
		<property name="Название" column="[Название]" />
		<property name="Цена" column="[Цена]" />
		<property name="Категория" column="[Категория]" />
		<property name="Калорийность" column="[Калорийность]" />
	</class>
</hibernate-mapping>