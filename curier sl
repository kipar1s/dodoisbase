@startuml
left to right direction

' --- Актёры ---
actor "Клиент" as Client
actor "Курьер" as Courier
actor "Менеджер Смены" as ShiftManager
actor "Пиццемейкер" as Pizzamaker
actor "Система оплаты" as PaymentSystem
actor "GPS-навигация" as GPS

' --- Прецеденты ---

' Группа: Заказ клиента
package "Клиентские действия" {
  (Сделать заказ) as order
  (Выбрать способ оплаты) as choosePayment
  (Оплатить заказ) as payOrder
  (Получить чек) as getReceipt
  (Отследить заказ) as trackOrder
  (Отменить заказ) as cancelOrder
  (Оценить доставку) as rateDelivery
  (Получить уведомление) as getNotification
  (Подать жалобу) as fileComplaint
  (Получить бонус) as getBonus
}

' Группа: Внутренние процессы
package "Обработка заказа" {
  (Принять заказ) as acceptOrder
  (Подготовить заказ) as prepareOrder
  (Передать заказ курьеру) as handoverToCourier
}

' Группа: Доставка
package "Доставка" {
  (Взять заказ на доставку) as takeOrder
  (Построить маршрут) as buildRoute
  (Доставить заказ) as deliverOrder
  (Получить оплату от клиента) as receiveCash
  (Подтвердить доставку) as confirmDelivery
}

' --- Ассоциации ---
Client --> order
Client --> choosePayment
Client --> trackOrder
Client --> cancelOrder
Client --> rateDelivery
Client --> getNotification
Client --> fileComplaint
Client --> getBonus

ShiftManager --> acceptOrder
ShiftManager --> handoverToCourier

Pizzamaker --> prepareOrder

Courier --> takeOrder
Courier --> buildRoute
Courier --> deliverOrder
Courier --> receiveCash
Courier --> confirmDelivery
Courier --> fileComplaint

' --- Внешние системы ---
PaymentSystem . .> payOrder : <<include>>
GPS . .> buildRoute : <<include>>

' --- Отношения между прецедентами ---

' Включения (<<include>>)
order ..> choosePayment : <<include>>
choosePayment ..> payOrder : <<include>>
payOrder ..> getReceipt : <<include>>
deliverOrder ..> buildRoute : <<include>>
prepareOrder ..> handoverToCourier : <<include>>

' Расширения (<<extend>>)
order ..> cancelOrder : <<extend>>
deliverOrder ..> receiveCash : <<extend>>
confirmDelivery ..> rateDelivery : <<extend>>
order ..> getBonus : <<extend>>
deliverOrder ..> fileComplaint : <<extend>>

' Обобщение (наследование)
' Оплата
payOrder <|-- (Оплатить картой)
payOrder <|-- (Оплатить наличными)
payOrder <|-- (Оплатить онлайн)

' Жалобы
fileComplaint <|-- (Клиент подаёт жалобу)
fileComplaint <|-- (Курьер подаёт жалобу)

note on link
  <<include>> — обязательное включение
  <<extend>> — опциональное расширение
  Обобщение — специализация прецедентов
end note

@enduml