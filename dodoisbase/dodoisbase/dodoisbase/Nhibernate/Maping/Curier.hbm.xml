<?xml version="1.0" encoding="utf-8" ?>
<!-- 
hibernate-mapping
	assembly - название сборки
	namespace - пространство имён приложения
	по умолчанию assembly и namespace совпадают
	с названием решения Visual Studio.
class name - имя класса, на который выполняется отображение
	по умолчанию совпадает с названием таблицы в базе данных.
	Если нужно отображение на таблицу с другим именем, используйте
	атрибут table.
property name - имя свойства класса, на которое отображается
	конкретное поле таблицы базы данных. По умолчанию имя
	свойства класса совпадает с именем поля таблицы. Если 
	нужно отображение на поле с другим именем, используйте
	атрибут column.
	



    
    
    
    
-->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2"
                   assembly="dodoisbase"
                   namespace="dodoisbase.Nhibernate.Entites">

	<class name="Curier" table="[Курьер]">
		<id name="ID_Курьера" column="[ID_Курьера]">
			<generator class="assigned" />
		</id>

		<many-to-one name="Сотрудник" column="[ID_Сотрудника]" cascade="merge" unique="true"/>

		<property name="Номер_ВУ" column="[Номер_ВУ]" />
		<property name="Телефон" column="[Телефон]" />
		<property name="Машина" column="[Машина]" />
		<property name="Номер_машины" column="[Номер_машины]" />

	</class>
</hibernate-mapping>
